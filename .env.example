APP_NAME=Browser SIP Calling
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

SIP_DOMAIN=pbx.example.com
SIP_WSS_URL=wss://pbx.example.com:8089/ws
SIP_WS_URL=ws://pbx.example.com:8088/ws
SIP_EXTENSION=7001
SIP_AUTH_USERNAME=7001
SIP_AUTH_PASSWORD=change-me
SIP_DISPLAY_NAME=Browser Agent

ASTERISK_AMI_ENABLED=false
ASTERISK_AMI_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USERNAME=admin
ASTERISK_AMI_SECRET=super-secret
ASTERISK_AMI_ORIGINATE_CONTEXT=from-internal
ASTERISK_AMI_ORIGINATE_EXTEN=_X.
ASTERISK_AMI_ORIGINATE_PRIORITY=1
ASTERISK_AMI_ORIGINATE_TIMEOUT_MS=30000
ASTERISK_AMI_CHANNEL_PREFIX=PJSIP

PUBLIC_DIAL_PREFIX=
