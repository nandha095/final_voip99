[global]
type=global
user_agent=Browser SIP Calling

[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0:5060
external_signaling_address=YOUR_PUBLIC_IP_OR_DNS
external_media_address=YOUR_PUBLIC_IP_OR_DNS
allow_reload=yes

[transport-wss]
type=transport
protocol=wss
bind=0.0.0.0
allow_reload=yes
external_signaling_address=YOUR_PUBLIC_IP_OR_DNS
external_media_address=YOUR_PUBLIC_IP_OR_DNS

; Browser WebRTC extension
[7001]
type=endpoint
context=from-internal
disallow=all
allow=opus,ulaw,alaw
webrtc=yes
use_avpf=yes
media_encryption=dtls
dtls_auto_generate_cert=yes
dtls_setup=actpass
ice_support=yes
rtcp_mux=yes
rewrite_contact=yes
force_rport=yes
rtp_symmetric=yes
direct_media=no
auth=7001-auth
aors=7001-aor
callerid=Browser Agent <7001>

[7001-auth]
type=auth
auth_type=userpass
username=7001
password=change-me

[7001-aor]
type=aor
max_contacts=5
remove_existing=yes

; Replace these trunk values with your provider details
[provider-auth]
type=auth
auth_type=userpass
username=TRUNK_USERNAME
password=TRUNK_PASSWORD

[provider-aor]
type=aor
contact=sip:sip.provider.example.com

[provider-registration]
type=registration
transport=transport-udp
outbound_auth=provider-auth
server_uri=sip:sip.provider.example.com
client_uri=sip:TRUNK_USERNAME@sip.provider.example.com
retry_interval=60
forbidden_retry_interval=600
expiration=300
line=yes
endpoint=provider-endpoint

[provider-endpoint]
type=endpoint
transport=transport-udp
context=from-provider
disallow=all
allow=ulaw,alaw
outbound_auth=provider-auth
aors=provider-aor
from_domain=sip.provider.example.com
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[provider-identify]
type=identify
endpoint=provider-endpoint
match=sip.provider.example.com
